# 루트 docker-compose 용 환경 변수. 복사해서 .env 로 사용: cp .env.example .env

# --- DB (postgres) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trading
# DB 호스트 노출 포트 (컨테이너 내부는 5432 고정)
POSTGRES_PORT=5432

# --- collector / KIS (기본: 모의투자) ---
COLLECTOR_KIS_ENV=paper
COLLECTOR_KIS_APP_KEY=여기에_앱키
COLLECTOR_KIS_APP_SECRET=여기에_앱시크릿

# --- collector 포트 ---
# COLLECTOR_HOST_PORT : 호스트에서 접속할 포트
# COLLECTOR_API_PORT  : 컨테이너 안에서 앱이 리슨하는 포트
COLLECTOR_HOST_PORT=8001
COLLECTOR_API_PORT=8000
COLLECTOR_API_HOST=0.0.0.0

# --- collector 수집 스케줄 (국장/미장 분리) ---
# 국장: 평일 16:00 KST / 미장: 화~토 07:00 KST (미 동부 마감 후)
COLLECTOR_DOMESTIC_CRON=0 16 * * mon-fri
COLLECTOR_OVERSEAS_CRON=0 7 * * tue-sat
COLLECTOR_TIMEZONE=Asia/Seoul
